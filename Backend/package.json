{
  "name": "giu-nexus-backend",
  "version": "1.0.0",
  "description": "GIU Nexus AI Career Intelligence Platform — Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/__tests__/setup.env.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/setup.env.js",
      "/__tests__/helpers/"
    ],
    "testTimeout": 60000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.47.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "jest": "^30.4.1",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
